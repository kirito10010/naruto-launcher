{
  "name": "naruto-online-launcher",
  "version": "1.0.4",
  "description": "火影忍者Online页游启动器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [
    "naruto",
    "flash",
    "game",
    "launcher"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^11.5.0",
    "electron-builder": "^22.14.13"
  },
  "build": {
    "appId": "com.example.naruto-launcher",
    "productName": "NarutoOnlineLauncher",
    "directories": {
      "output": "release-v1.0.4"
    },
    "icon": "resources/icons/Naruto.png",
    "files": [
      "main.js",
      "preload.js",
      "launcher.html"
    ],
    "extraResources": [
      {
        "from": "resources/flash/",
        "to": "flash"
      },
      {
        "from": "resources/native/",
        "to": "native"
      },
      {
        "from": "resources/icons/",
        "to": "icons"
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "kirito10010",
      "repo": "naruto-launcher",
      "private": false
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
